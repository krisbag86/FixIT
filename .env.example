# Baza danych (podpinana przy deployu na Railway; lokalnie uzywany jest JSON-store)
DATABASE_URL="postgresql://user:password@localhost:5432/fixit"

# Publiczny adres aplikacji - uzywany do budowy linkow w mailach (magic link).
# Lokalnie przez Docker: http://localhost:3001, przez npm run dev: http://localhost:3000
APP_URL="http://localhost:3000"

# Wysylka email przez Resend. Gdy brak RESEND_API_KEY, maile sa logowane do konsoli (tryb dev).
RESEND_API_KEY=""
EMAIL_FROM="FixIT Helpdesk <no-reply@bagietka.pl>"

# Czas waznosci linku logowania w minutach (domyslnie 15).
MAGIC_LINK_TTL_MINUTES="15"
