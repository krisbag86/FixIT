# =============================================================================
# FixIT Helpdesk - Environment Variables
# Copy this file to .env for local development.
# On Railway, set these via the Dashboard > Variables tab.
# =============================================================================

# --- Database (PostgreSQL) ---
# Railway auto-injects this when you add a PostgreSQL service.
# Example: postgresql://user:password@host:port/db
DATABASE_URL="postgresql://user:password@localhost:5432/fixit"

# --- App URL ---
# Used for links in email notifications. Must match your Railway domain.
# For local dev: http://localhost:3001
# For Railway: https://your-app.railway.app
APP_URL="http://localhost:3000"

# --- Cookie Secret for Session Signing ---
# Generate with: openssl rand -hex 32
# Required in production. On Railway, set a strong random value.
COOKIE_SECRET="change-me-to-a-random-string-in-production"

# --- Email (SMTP) ---
# Configure for email notifications. On Railway, use a transactional email provider.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="IT Helpdesk <it@bagietka.pl>"

# --- Attachment Storage ---
# Railway has an ephemeral filesystem - files are lost on redeploy.
# For persistent attachments, configure Railway Bucket (S3-compatible) and set:
# S3_ENDPOINT="https://your-bucket.railway.app"
# S3_REGION="auto"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
# S3_BUCKET="your-bucket-name"
#
# Without these, attachments are stored on the local filesystem
# and will be lost on every Railway deployment.

# --- Data Provider ---
# By default, the app auto-detects:
#   Production (NODE_ENV=production) + DATABASE_URL set -> Prisma
#   Otherwise -> JSON file store (for local dev without PostgreSQL)
# You can override with:
# FIXIT_DATA_PROVIDER=prisma   # force Prisma (requires running database)
# FIXIT_DATA_PROVIDER=json     # force JSON file store

# --- First Deploy on Railway ---
# On your very first deploy, uncomment this to seed initial test data:
# FIXIT_RUN_SEED=true
# After the first deploy succeeds, REMOVE or set to false to avoid duplicate data.
